    {
      "name": "Network v2",
      "item": [
        {
          "name": "Bandwidth probe — download",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/bandwidth-probe?size_kb=256",
              "host": ["{{base_url}}"],
              "path": ["bandwidth-probe"],
              "query": [
                {"key": "size_kb", "value": "256", "description": "Payload size in KB (4–512, default 256)"}
              ]
            },
            "description": "Returns a binary payload for browser-side download speed measurement.\n\nThe browser times the fetch: `Mbps = (size_bytes × 8) / seconds / 1_000_000`.\n\n`Cache-Control: no-store` prevents caching."
          },
          "response": [
            {
              "name": "256KB payload",
              "status": "OK",
              "code": 200,
              "header": [
                {"key": "Content-Type", "value": "application/octet-stream"},
                {"key": "Content-Length", "value": "262144"},
                {"key": "Cache-Control", "value": "no-store, no-cache"}
              ]
            }
          ]
        },
        {
          "name": "Bandwidth probe — upload",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/bandwidth-probe",
              "host": ["{{base_url}}"],
              "path": ["bandwidth-probe"]
