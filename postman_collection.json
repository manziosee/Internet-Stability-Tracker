    {
      "name": "Community Reports",
      "item": [
        {
          "name": "List reports",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reports?skip=0&limit=50",
              "host": ["{{base_url}}"],
              "path": ["reports"],
              "query": [
                {"key": "skip",  "value": "0",  "description": "Offset"},
                {"key": "limit", "value": "50", "description": "Max records (1–500)"}
              ]
            },
            "description": "All community-submitted reports. Includes `confirmations`, `rejections`, and `status` (pending / confirmed / resolved)."
          }
        },
        {
          "name": "Submit a report",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/reports",
              "host": ["{{base_url}}"],
              "path": ["reports"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isp\": \"MTN Rwanda\",\n  \"location\": \"Kigali, Kimironko\",\n  \"latitude\": -1.9441,\n  \"longitude\": 30.0619,\n  \"issue_type\": \"outage\",\n  \"description\": \"Complete loss of connectivity since 09:00 — no signal on LTE or fibre backup.\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "description": "Submit a crowd-sourced network issue.\n\n**issue_type** must be one of: `outage` | `slow` | `intermittent` | `other`\n\n**Rate limited**: 20 req / 60 s per IP."
          },
          "response": [
            {
              "name": "Created",
              "status": "Created",
              "code": 201,
              "body": "{\"id\":1,\"timestamp\":\"2026-03-11T15:00:00\",\"isp\":\"MTN Rwanda\",\"location\":\"Kigali, Kimironko\",\"latitude\":-1.9441,\"longitude\":30.0619,\"issue_type\":\"outage\",\"description\":\"Complete loss of connectivity since 09:00 — no signal on LTE or fibre backup.\",\"status\":\"pending\",\"confirmations\":0,\"rejections\":0}"
            },
            {
              "name": "Validation Error",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{\"detail\":[{\"loc\":[\"body\",\"issue_type\"],\"msg\":\"issue_type must be one of {'outage', 'slow', 'intermittent', 'other'}\",\"type\":\"value_error\"}]}"
            }
          ]
        },
        {
          "name": "Get report by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reports/{{report_id}}",
              "host": ["{{base_url}}"],
              "path": ["reports", "{{report_id}}"]
            },
            "description": "Get a single community report including `confirmations`, `rejections`, and `status`.\n\nUpdate the `report_id` collection variable after creating a report."
          },
          "response": [
            {
              "name": "Found",
              "status": "OK",
              "code": 200,
              "body": "{\"id\":1,\"timestamp\":\"2026-03-11T15:00:00\",\"isp\":\"MTN Rwanda\",\"location\":\"Kigali, Kimironko\",\"latitude\":-1.9441,\"longitude\":30.0619,\"issue_type\":\"outage\",\"description\":\"Complete loss.\",\"status\":\"confirmed\",\"confirmations\":3,\"rejections\":0}"
            },
            {
              "name": "Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\"detail\":\"Report not found\"}"
            }
          ]
        },
        {
          "name": "Confirm report",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/reports/{{report_id}}/confirm",
              "host": ["{{base_url}}"],
              "path": ["reports", "{{report_id}}", "confirm"]
            },
            "description": "Upvote a community report — increments `confirmations`.\n\nWhen `confirmations` reaches 3, `status` is automatically set to `confirmed`.\n\nUpdate the `report_id` collection variable to target a specific report."
          },
          "response": [
            {
              "name": "Confirmed",
              "status": "OK",
              "code": 200,
              "body": "{\"id\":1,\"timestamp\":\"2026-03-11T15:00:00\",\"isp\":\"MTN Rwanda\",\"location\":\"Kigali, Kimironko\",\"latitude\":-1.9441,\"longitude\":30.0619,\"issue_type\":\"outage\",\"description\":\"Complete loss.\",\"status\":\"confirmed\",\"confirmations\":3,\"rejections\":0}"
            }
          ]
        },
        {
          "name": "Reject report",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/reports/{{report_id}}/reject",
              "host": ["{{base_url}}"],
              "path": ["reports", "{{report_id}}", "reject"]
            },
            "description": "Downvote a community report — increments `rejections`.\n\nWhen `rejections` reaches 3, `status` is automatically set to `resolved`.\n\nUpdate the `report_id` collection variable to target a specific report."
          },
          "response": [
            {
              "name": "Rejected",
              "status": "OK",
              "code": 200,
              "body": "{\"id\":1,\"timestamp\":\"2026-03-11T15:00:00\",\"isp\":\"MTN Rwanda\",\"location\":\"Kigali, Kimironko\",\"latitude\":-1.9441,\"longitude\":30.0619,\"issue_type\":\"outage\",\"description\":\"Complete loss.\",\"status\":\"resolved\",\"confirmations\":0,\"rejections\":3}"
            }
          ]
        }
      ]
    },
