    {
      "name": "Community Reports",
      "item": [
        {
          "name": "List reports",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reports?skip=0&limit=20",
              "query": [
                { "key": "skip", "value": "0" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Submit report",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Client-ID", "value": "{{client_id}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isp\": \"My ISP\",\n  \"location\": \"Kigali, Rwanda\",\n  \"issue_type\": \"outage\",\n  \"description\": \"Complete internet outage since 9am\"\n}"
            },
            "url": { "raw": "{{base_url}}/reports" }
          }
        },
        {
          "name": "Get single report",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/reports/{{report_id}}" }
          }
        },
        {
          "name": "Confirm report",
          "request": {
            "method": "POST",
            "header": [{ "key": "X-Client-ID", "value": "{{client_id}}" }],
            "url": { "raw": "{{base_url}}/reports/{{report_id}}/confirm" }
          }
        },
        {
          "name": "Reject report",
          "request": {
            "method": "POST",
            "header": [{ "key": "X-Client-ID", "value": "{{client_id}}" }],
            "url": { "raw": "{{base_url}}/reports/{{report_id}}/reject" }
          }
        }
      ]
