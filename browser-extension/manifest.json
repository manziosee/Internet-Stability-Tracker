{
  "manifest_version": 3,
  "name": "NetPulse - Internet Speed & Stability Tracker",
  "short_name": "NetPulse",
  "version": "1.3.0",
  "description": "Real-time internet speed monitor & outage detector. Auto speed tests, live badge, health score, ISP tracker, ping & packet loss monitor, WFH score. Works in Chrome, Firefox, Edge, Brave, Opera.",

  "homepage_url": "https://internet-stability-tracker.vercel.app",
  "keywords": ["internet speed", "speed test", "network monitor", "outage detector", "ping", "wifi", "ISP tracker", "packet loss", "WFH"],

  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "activeTab",
    "contextMenus",
    "clipboardWrite"
  ],

  "host_permissions": [
    "https://backend-cold-butterfly-9535.fly.dev/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "NetPulse - Internet Speed & Stability Tracker"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "ist@internet-stability-tracker.app",
      "strict_min_version": "109.0"
    }
  },

  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; connect-src https://backend-cold-butterfly-9535.fly.dev https://internet-stability-tracker.vercel.app; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
  }
}
