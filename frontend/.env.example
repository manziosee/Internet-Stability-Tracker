# ── Internet Stability Tracker — Frontend Environment Variables ────────────────
# For local dev (without Docker):  copy to .env.local
#   cp .env.example .env.local
# For Docker / production:  pass as build arg  REACT_APP_API_URL=/api
#
# Never commit .env.local — it is gitignored.

# Backend API base URL.
# Local dev (no Docker):   http://localhost:8000/api
# Docker Compose:          /api   (nginx proxies /api → backend:8000)
# Vercel / Fly.io:         /api   (set at build time via CI)
REACT_APP_API_URL=http://localhost:8000/api
