# ── Internet Stability Tracker — Backend Environment Variables ─────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# Never commit .env — it is gitignored.

# ── Turso / libSQL cloud database ─────────────────────────────────────────────
# Get from: https://turso.tech → your database → Connect
TURSO_DB_URL=libsql://your-db-name.aws-us-east-1.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# ── Application ───────────────────────────────────────────────────────────────
# Generate a strong key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-strong-random-secret-key

# Admin key for the DELETE /api/measurements endpoint.
# Leave empty to disable the endpoint entirely.
# Generate:  python -c "import secrets; print(secrets.token_hex(24))"
ADMIN_API_KEY=replace-with-a-strong-admin-key

ENVIRONMENT=development           # development | production
SPEED_TEST_INTERVAL=300           # seconds between background speed tests
AUTO_SPEED_TEST=false             # set true to enable the background scheduler
OUTAGE_THRESHOLD_MBPS=1.0         # speeds below this (Mbps) count as an outage

# Comma-separated list of allowed CORS origins (JSON array format)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── Smart Alerts (optional) ───────────────────────────────────────────────────
# Telegram Bot
TELEGRAM_BOT_TOKEN=              # Get from @BotFather on Telegram

# Twilio SMS (for critical alerts)
TWILIO_ACCOUNT_SID=              # From twilio.com/console
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=              # Your Twilio phone number

# ── Caching (optional) ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0  # Leave empty to disable caching

# ── Go agent sidecar ──────────────────────────────────────────────────────────
# URL of the go-agent service (port 8002 in the same container).
# Set to empty string to disable and fall through to Redis / in-memory cache.
AGENT_URL=http://127.0.0.1:8002

# Shared secret for Python → Go service-to-service auth.
# Must match AGENT_SERVICE_TOKEN set on the Go binary.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AGENT_SERVICE_TOKEN=

# Go agent tuning (read by go-agent binary, not by Python)
AGENT_PORT=8002
AGENT_CACHE_MAX_SIZE=2000    # maximum LRU entries
AGENT_CACHE_TTL_SEC=30       # default entry TTL in seconds
AGENT_MAX_BODY_BYTES=524288  # max POST body (512 KiB)

# ── Rust probe sidecar ────────────────────────────────────────────────────────
# URL of the ist-probe Rust service (runs on port 8001 in the same container).
# Set to empty string to disable and use Python-only fallback probes.
PROBE_URL=http://127.0.0.1:8001

# Rust probe service tuning (read by ist-probe binary, not Python)
PROBE_PORT=8001                    # port ist-probe listens on
PROBE_DEFAULT_HOST=8.8.8.8         # default probe target
PROBE_DEFAULT_TCP_PORT=443         # TCP port used for RTT probes
PROBE_TIMEOUT_MS=2000              # per-probe timeout (ms)
PROBE_MAX_CONCURRENT=50            # max concurrent packet-loss probes
# PROBE_BANDWIDTH_URLS=https://speed.cloudflare.com/__down?bytes=25000000,...
