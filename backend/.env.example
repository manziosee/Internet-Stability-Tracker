# ── Turso (libSQL) Cloud Database ─────────────────────────────────────────────
TURSO_DB_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# ── App Settings ──────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret
ENVIRONMENT=development

# How often to run automatic speed tests (seconds)
SPEED_TEST_INTERVAL=300

# Download speed below this value (Mbps) is classified as an outage
OUTAGE_THRESHOLD_MBPS=1.0

# Allowed frontend origins (JSON array)
# CORS_ORIGINS=["http://localhost","http://localhost:3000","https://yourdomain.com"]

# Maximum hours of history served by /measurements/recent and /stats
MAX_HISTORY_HOURS=168
