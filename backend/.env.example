# ── Internet Stability Tracker — Backend Environment Variables ─────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# Never commit .env — it is gitignored.

# ── Turso / libSQL cloud database ─────────────────────────────────────────────
# Get from: https://turso.tech → your database → Connect
TURSO_DB_URL=libsql://your-db-name.aws-us-east-1.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# ── Application ───────────────────────────────────────────────────────────────
# Generate a strong key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-strong-random-secret-key

# Admin key for the DELETE /api/measurements endpoint.
# Leave empty to disable the endpoint entirely.
# Generate:  python -c "import secrets; print(secrets.token_hex(24))"
ADMIN_API_KEY=replace-with-a-strong-admin-key

ENVIRONMENT=development           # development | production
SPEED_TEST_INTERVAL=300           # seconds between background speed tests
AUTO_SPEED_TEST=false             # set true to enable the background scheduler
OUTAGE_THRESHOLD_MBPS=1.0         # speeds below this (Mbps) count as an outage

# Comma-separated list of allowed CORS origins (JSON array format)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
